# =========================================
# Media files inside uploads/ (track folders, ignore files)
# =========================================
# Images
uploads/**/*.{jpg,jpeg,png,gif,webp,bmp,tiff,tif,svg,ico,heic,psd,ai,eps,pdf,sketch,xcf,raw,indd,cdr,swf}

# Videos
uploads/**/*.{mp4,mov,avi,mkv,wmv,flv,webm,m4v,mpeg,mpg,3gp,ogg}

# Audio
uploads/**/*.{mp3,wav,aac,flac,m4a,wma,aiff,alac,ogg}

# =========================================
# Other media / design files
# =========================================
uploads/**/*.{sketch,xcf,raw,indd,cdr,swf}